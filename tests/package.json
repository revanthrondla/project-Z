{
  "name": "flow-tests",
  "version": "1.0.0",
  "description": "Flow — E2E and unit test suite",
  "private": true,
  "scripts": {
    "test:e2e":          "playwright test --config=e2e/playwright.config.js",
    "test:e2e:auth":     "playwright test --config=e2e/playwright.config.js e2e/auth.spec.js",
    "test:e2e:admin":    "playwright test --config=e2e/playwright.config.js e2e/admin.spec.js",
    "test:e2e:employee": "playwright test --config=e2e/playwright.config.js e2e/employee.spec.js",
    "test:e2e:brand":    "playwright test --config=e2e/playwright.config.js e2e/branding.spec.js",
    "test:e2e:responsive":"playwright test --config=e2e/playwright.config.js e2e/responsive.spec.js",
    "test:e2e:ai":       "playwright test --config=e2e/playwright.config.js e2e/ai-chat.spec.js",
    "test:e2e:superadmin":"playwright test --config=e2e/playwright.config.js e2e/superadmin.spec.js",
    "test:e2e:mobile":   "playwright test --config=e2e/playwright.config.js --project=mobile-chrome --project=mobile-safari",
    "test:e2e:headed":   "playwright test --config=e2e/playwright.config.js --headed",
    "test:e2e:ui":       "playwright test --config=e2e/playwright.config.js --ui",
    "test:e2e:debug":    "playwright test --config=e2e/playwright.config.js --debug",
    "test:e2e:report":   "playwright show-report reports/playwright",
    "test:e2e:skip-start":"SKIP_WEBSERVER=true playwright test --config=e2e/playwright.config.js",
    "install:browsers":  "playwright install --with-deps chromium firefox"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0"
  }
}
