# ── Node modules ──────────────────────────────────────────────────────────────
node_modules
backend/node_modules
frontend/node_modules

# ── Build artefacts ───────────────────────────────────────────────────────────
frontend/dist
backend/uploads/*
!backend/uploads/.gitkeep

