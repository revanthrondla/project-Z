.env
backend/.env
**/.env.local

# ── Development / CI ──────────────────────────────────────────────────────────
backend/tests/
backend/jest.config.js
backend/test_*.db*
ecosystem.config.js
docker-compose.*.yml
screenshots/
docs/

# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Editor / OS ───────────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
.vscode/
.idea/
Thumbs.db
