# ─────────────────────────────────────────────────────────────────────────────
# HireIQ Backend — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before starting the server.
# NEVER commit .env to version control — it contains secrets.
#
# Generate random secrets:
#   JWT_SECRET:      node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   ENCRYPTION_KEY:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001


# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED — must be a cryptographically random string (64+ bytes recommended)
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET

# JWT token lifetime (default: 7d)
# JWT_EXPIRES_IN=7d


# ── Database paths ────────────────────────────────────────────────────────────
# Directory where master.db and all per-tenant .db files are stored.
# In Docker: mount a named volume here so data persists across container restarts.
HIREIQ_DATA_DIR=/data

# Legacy single-tenant DB path (used if HIREIQ_DATA_DIR is not set).
# Set to an absolute path inside a mounted volume in production.
HIREIQ_DB_PATH=/data/hireiq.db


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Include your custom domain and any www variant.
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com


# ── Encryption ────────────────────────────────────────────────────────────────
# REQUIRED if using email payment polling — used to encrypt stored IMAP passwords.
# Must be exactly 32 bytes of hex (64 hex characters).
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX


# ── AI Assistant (optional) ───────────────────────────────────────────────────
# Required only if the ai_assistant module is enabled for any tenant.
# Anthropic Claude API key — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI API key (fallback / alternative AI provider)
OPENAI_API_KEY=


# ── Email Payment Polling (optional) ─────────────────────────────────────────
# These are configured per-tenant in the app (Settings → Email Payments).
# The IMAP passwords are encrypted in the database using ENCRYPTION_KEY above.
# EMAIL_HOST=imap.gmail.com
# EMAIL_PORT=993
# EMAIL_USER=payments@yourdomain.com
# EMAIL_PASS=your_app_password


# ── Uploads ───────────────────────────────────────────────────────────────────
# Directory where uploaded files (documents, resumes, CSV imports) are stored.
# In Docker: use a named volume mounted at /app/uploads (see docker-compose.yml).
# UPLOAD_DIR=/data/uploads

# Maximum upload file size (default: 10mb — set in server.js)
# UPLOAD_LIMIT=10mb


# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Configured in server.js. Reference values:
# AUTH_RATE_LIMIT_MAX=5         (login attempts per 15 min per IP, production)
# API_RATE_LIMIT_MAX=300        (API requests per minute per IP)


# ── Logging ───────────────────────────────────────────────────────────────────
# Morgan log format: 'combined' (Apache-style) in production, 'dev' in development
# Controlled automatically by NODE_ENV — no override needed in most cases.
# LOG_FORMAT=combined
